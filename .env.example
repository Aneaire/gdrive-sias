# Convex deployment (set by `bunx convex dev`)
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=

# Server-side secrets (set via `bunx convex env set`)
# Google OAuth client used by the in-app "Connect Google Drive" button (one client for all tenants)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# HMAC secret for signing the OAuth `state` JWT (32+ bytes base64)
OAUTH_STATE_SECRET=
# AES-256-GCM key for encrypting per-tenant refresh tokens (32 bytes base64)
ENCRYPTION_KEY=