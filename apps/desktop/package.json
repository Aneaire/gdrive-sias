{
  "name": "@gcustomize/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for the packaged RIELAN / G-customize survey product",
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "convex": "^1.42.0"
  },
  "devDependencies": {
    "electron": "42.3.2",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.gcustomize.desktop",
    "productName": "Survey File System",
    "directories": { "output": "dist" },
    "files": ["src/**/*", "assets/**/*", "package.json", ".env"],
    "icon": "assets/icon.png",
    "extraResources": [
      {
        "from": "../web/.vercel/output",
        "to": "web-output"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-${os}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Survey File System"
    },
    "linux": {
      "target": ["dir"],
      "category": "Utility",
      "icon": "assets/icon.png"
    }
  }
}