{
  "extends": "./tsconfig.base.json",
  "include": [
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/node_modules/vite/client.d.ts",
    "convex/**/*.ts"
  ],
  "exclude": ["node_modules", "apps/desktop/dist", "apps/mobile/.expo", "apps/mobile/node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "#/*": ["./apps/web/src/*"],
      "@/*": ["./apps/web/src/*"],
      "@convex/*": ["./convex/*"]
    },
    "typeRoots": [
      "./apps/web/node_modules/@types",
      "./node_modules/@types"
    ],
    "types": ["node"]
  }
}